# ========================================
# AI-SDR Backend Production Configuration
# ========================================
# Copy this file to .env.production and fill in your values

# Server Configuration
PORT=4000
NODE_ENV=production

# IMPORTANT: Update these with your production domain
PUBLIC_BASE_URL=https://yourdomain.com
FRONTEND_ORIGIN=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ========================================
# Database (Neon PostgreSQL)
# ========================================
# Get this from your Neon dashboard
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/ai_sdr?sslmode=require

# ========================================
# Redis (Upstash Redis)
# ========================================
# Get this from your Upstash dashboard
# Must use rediss:// for TLS connection
REDIS_URL=rediss://default:your-password@region.upstash.io:6379

# ========================================
# Twilio Configuration
# ========================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ========================================
# OpenAI Configuration
# ========================================
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========================================
# TTS Configuration
# ========================================
# ElevenLabs (Primary TTS)
ELEVEN_API_KEY=your-elevenlabs-api-key
ELEVEN_VOICE_ID_MALE=pNInz6obpgDQGcFmaJgB  # Adam
ELEVEN_VOICE_ID_FEMALE=EXAVITQu4vr4xnSDxMaL  # Sarah

# Chatterbox (Fallback TTS)
USE_CHATTERBOX=false
CHATTERBOX_VOICE_MALE=alex
CHATTERBOX_VOICE_FEMALE=sarah

# Deepgram (Optional)
USE_DEEPGRAM=false
DEEPGRAM_API_KEY=

# XTTS (Optional)
USE_XTTS=false
XTTS_URL=

# ========================================
# Security & Monitoring
# ========================================
# Rate Limiting (ENABLED in production)
ENABLE_RATE_LIMITING=true

# Encryption Key (REQUIRED for Production)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-character-hex-key-here-generate-a-new-one

# Sentry Error Monitoring (Highly Recommended)
SENTRY_DSN=https://your-sentry-dsn@o123456.ingest.sentry.io/7654321

# ========================================
# Optional Integrations
# ========================================
# HubSpot
HUBSPOT_ACCESS_TOKEN=

# SendGrid Email
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=AI SDR

# LinkedIn Enrichment (RapidAPI)
RAPIDAPI_KEY=your-rapidapi-key-here

# ========================================
# Production Settings
# ========================================
# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Trust proxy (for rate limiting behind Nginx)
TRUST_PROXY=true

# CORS settings (automatically set from FRONTEND_ORIGIN)
# No need to set CORS_ORIGIN separately

# ========================================
# Feature Flags
# ========================================
# Enable/disable features
ENABLE_LINKEDIN_ENRICHMENT=true
ENABLE_SCRIPT_GENERATION=true
ENABLE_VOICE_CALLS=true
