# Azure AD Configuration
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-app-client-id-here
AZURE_CLIENT_SECRET=your-app-client-secret-here

# Twilio Configuration (for SMS OTP)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# SMTP Configuration (for Email OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASSWORD=your-smtp-password

# Redis Configuration (for OTP storage)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Secret (for password reset tokens)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ManageEngine ServiceDesk Configuration
MANAGEENGINE_URL=https://servicedesk.exide.com
MANAGEENGINE_API_KEY=your-manageengine-api-key

# Application Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# OTP Configuration
OTP_EXPIRY_SECONDS=300
OTP_LENGTH=6
MAX_OTP_ATTEMPTS=3

# Rate Limiting
MAX_UNLOCK_REQUESTS_PER_HOUR=3
MAX_OTP_REQUESTS_PER_HOUR=5

# Polling Configuration (in milliseconds)
LOCKOUT_POLL_INTERVAL=30000
