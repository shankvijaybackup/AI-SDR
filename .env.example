# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_sdr?schema=public"

# JWT Secret (generate a random 32+ char string)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Next.js
NEXT_PUBLIC_API_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Backend API
BACKEND_API_URL="http://localhost:4000"
NEXT_PUBLIC_BACKEND_URL="http://localhost:4000"

# AI Providers (Claude + Groq + Voyage AI — replaces OpenAI/Gemini)
ANTHROPIC_API_KEY="sk-ant-..."
GROQ_API_KEY="gsk_..."
VOYAGE_API_KEY="pa-..."

# Web Search for Research & Enrichment (Tavily primary, Exa fallback)
TAVILY_API_KEY="tvly-..."
EXA_API_KEY="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Perplexity (for persona deep research — keep alongside Tavily)
PERPLEXITY_API_KEY="pplx-..."

# SendGrid Email
SENDGRID_API_KEY="SG.xxxx"
FROM_EMAIL="notifications@yourdomain.com"

# Twilio (Backend)
TWILIO_ACCOUNT_SID="ACxxxx"
TWILIO_AUTH_TOKEN="xxxx"
TWILIO_PHONE_NUMBER="+1xxxxxxxxxx"
